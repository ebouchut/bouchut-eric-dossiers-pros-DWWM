{
  "name": "dwwm-diaporama",
  "version": "1.0.0",
  "private": true,
  "description": "DWWM oral-defense slideshow built with Slidev",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "slidev slides.md --open",
    "export:pdf": "slidev export slides.md --output ../bouchut-eric-diaporama.pdf",
    "export:pptx": "slidev export slides.md --format pptx --output ../bouchut-eric-diaporama.pptx",
    "build": "slidev build slides.md"
  },
  "devDependencies": {
    "@slidev/cli": "^52.18.0",
    "@slidev/theme-default": "^0.25.0",
    "playwright-chromium": "^1.61.1"
  }
}
